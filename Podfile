def shared
    pod 'Firebase/Analytics'
    pod 'Firebase/Crashlytics'
    pod 'DynamicColor'
    pod 'TinyConstraints'
end

target 'Keyboard' do
    use_frameworks! # :linkage => :static
    
    shared
    
    pod 'SwiftyTimer'
end

target 'NumPad' do
    use_frameworks! # :linkage => :static
    
    shared
    
    pod 'SwiftRater'
    pod 'RevealingSplashView', :git => 'https://github.com/PiXeL16/RevealingSplashView.git'
    pod 'TextAttributes'
end
